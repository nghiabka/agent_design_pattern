OPENAI_API_BASE=http://127.0.0.1:1234/v1
OPENAI_API_KEY=local-key
OPENAI_MODEL_NAME=local-model

# So vong retrieve/rewrite toi da truoc khi bat buoc tra loi
MAX_RETRIEVAL_ROUNDS=3

# Backend API cho Streamlit frontend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://localhost:8000

# Langfuse tracing
# Set LANGFUSE_ENABLED=false neu muon tat tracing ma khong xoa keys.
LANGFUSE_ENABLED=true
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
